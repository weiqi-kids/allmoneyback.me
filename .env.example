# GA4 Measurement ID — 填入你的 G-XXXXXXXX 後 GA4 才會注入頁面；留空不注入。
# 複製此檔為 .env（或在部署平台設定環境變數），.env 已被 .gitignore 排除。
PUBLIC_GA4_MEASUREMENT_ID=

# 互動後端（C3 Cloudflare Worker）的 API base URL，例如
#   https://interaction.<your-subdomain>.workers.dev
# 留空 → 前台留言島與委託投題表單一律降級為「尚未啟用」提示，不發任何請求、不報錯。
# 站長在部署 workers/interaction（見 OPERATIONS.md）後再填入。
PUBLIC_INTERACTION_API=
