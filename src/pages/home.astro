---
// 品牌正門 /home —— 網址即咒：all money back me home＝唵嘛呢叭咪吽。
// 見證之眼（集體、不具象成單一人物）：記錄全世界賺錢的方式與結果，不替你判對錯。
import Base from '@/layouts/Base.astro';
import Button from '@/components/ui/Button.astro';
import { withBase } from '@/utils/url';
import { SITE_NAME } from '@/data/site';
---

<Base
  title={`${SITE_NAME}｜all money back me home`}
  description="我們見證全世界各種賺錢的活法與它們的結果，只記錄、不替你判對錯——判斷留給你。"
  lang="zh"
>
  <section class="front container">
    <p class="front__mantra" aria-label="all money back me home，唵嘛呢叭咪吽">
      all&nbsp;money&nbsp;back&nbsp;me&nbsp;home
      <span class="front__mantra-zh">唵 嘛呢 叭 咪 吽</span>
    </p>

    <h1 class="front__title">{SITE_NAME}</h1>

    <div class="front__lead">
      <p>我們見證全世界各種賺錢的活法，與它們的結果。</p>
      <p>
        誰靠加班，誰靠借貸，誰靠攢一輩子，誰靠一場運氣——
        各自走得不一樣，也各自走向不一樣的結局。
      </p>
      <p>
        我們只把方式與後果記下來、攤開；<strong>不替你判誰對誰錯。</strong>
        判斷留給你。
      </p>
      <p class="front__vow">願你追的那條路，終究回得了家。</p>
    </div>

    <div class="front__actions">
      <Button variant="primary" href={withBase('/zh/articles/')}>看見證記錄</Button>
      <Button variant="secondary" href={withBase('/zh/about/')}>關於這雙眼睛</Button>
    </div>
  </section>
</Base>

<style>
  .front {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding-block: clamp(3rem, 2rem + 6vw, 6rem);
    max-width: 46rem;
  }
  .front__mantra {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    letter-spacing: 0.04em;
    color: var(--color-accent);
    margin: 0;
  }
  .front__mantra-zh {
    display: block;
    margin-top: 0.35rem;
    font-size: var(--text-base);
    letter-spacing: 0.5em;
    color: var(--color-ink);
    opacity: 0.55;
  }
  .front__title {
    font-size: var(--text-3xl);
    line-height: 1.1;
    margin: 0;
  }
  .front__lead {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--color-ink);
  }
  .front__lead p {
    margin: 0;
  }
  .front__vow {
    color: var(--color-accent);
    font-family: var(--font-serif);
  }
  .front__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.75rem;
  }
</style>
