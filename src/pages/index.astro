---
// 根路徑 → 品牌正門 /home（網址本身唸作 all money back me home）。
// 立即轉址（0 秒 meta refresh + JS location.replace + 後備連結），base-aware。
// 不用 Astro.redirect：它在靜態輸出會產生 content="2"（延遲 2 秒），體感像沒在轉。
import { withBase } from '@/utils/url';
const target = withBase('/home/');
---

<!doctype html>
<html lang="zh">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <script is:inline define:vars={{ target }}>
      location.replace(target);
    </script>
    <title>錢途</title>
  </head>
  <body>
    <p>前往 <a href={target}>錢途</a>……</p>
  </body>
</html>
