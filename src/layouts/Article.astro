---
import Base from '@/layouts/Base.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import CategoryTag from '@/components/ui/CategoryTag.astro';
import AuthorMeta from '@/components/blocks/AuthorMeta.astro';
import TldrBox from '@/components/blocks/TldrBox.astro';
import FaqAccordion from '@/components/blocks/FaqAccordion.astro';
import ReferenceList from '@/components/blocks/ReferenceList.astro';
import AiDisclosure from '@/components/blocks/AiDisclosure.astro';
import Comments from '@/components/interaction/Comments.svelte';
import JsonLd from '@/components/seo/JsonLd.astro';
import { AUTHOR_NAME, SITE_NAME } from '@/data/site';
import { withBase } from '@/utils/url';
import type { ArticleCategorySlug } from '@/utils/article-categories';
import type { Source } from '@/schemas/articles';

interface Props {
  title: string;
  description: string;
  seoTitle?: string;
  socialTitle?: string;
  socialDescription?: string;
  ogImage?: string;
  /** Article slug (post.id); used to resolve the per-article generated OG image. */
  ogSlug?: string;
  lang?: 'zh' | 'en';
  category: ArticleCategorySlug;
  variant?: 'prose' | 'cards';
  publishDate: Date;
  updatedDate: Date;
  readingTime?: number;
  breadcrumbItems: Array<{ label: string; href?: string }>;
  faq?: Array<{ q: string; a: string }>;
  sources?: Source[];
  citationAnswer?: string;
  /** AI 生成的封面圖（相對路徑或已 import 的 ImageMetadata）。為保留 C2PA 不經 Astro 最佳化。 */
  coverImage?: string | { src: string };
  /** 封面圖的 C2PA Content Credentials 是否已於 build 時驗證通過（E13）。 */
  coverC2paVerified?: boolean;
  // 見證軸（spec：賺錢方式 × 結果 × 見證引子）
  method?: string;
  outcome?: string;
  witnessVigil?: string;
  // 分歧框架（spec §3）
  anchorCulture: string;
  comparedCultures: string[];
  suspectCultures?: string[];
  // 生成資訊揭露
  writeModel?: string;
  critiqueModel?: string;
  pipelineVersion?: string;
  specVersion?: string;
}

const {
  title,
  description,
  seoTitle,
  socialTitle,
  socialDescription,
  ogImage,
  ogSlug,
  lang = 'zh',
  category,
  variant = 'prose',
  publishDate,
  updatedDate,
  readingTime,
  breadcrumbItems,
  faq,
  sources,
  citationAnswer,
  coverImage,
  coverC2paVerified,
  method,
  outcome,
  witnessVigil,
  anchorCulture,
  comparedCultures,
  suspectCultures = [],
  writeModel,
  critiqueModel,
  pipelineVersion,
  specVersion,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const updatedDiffers = updatedDate.getTime() !== publishDate.getTime();

// 互動後端 base URL（C3 Worker）。未設定 → 留言島自行降級為「尚未啟用」。
// 留言 slug 用文章 slug（post.id），即傳入的 ogSlug。
const interactionApi = import.meta.env.PUBLIC_INTERACTION_API ?? '';

// Per-article generated OG image (satori → sharp PNG, emitted by
// src/pages/og/zh/[...slug].png.ts). Absolute + base-aware so it resolves under
// both the production apex domain and the github.io preview base. An explicit
// `ogImage` prop still wins if a caller passes one.
const ogImageUrl =
  ogImage ??
  (ogSlug
    ? new URL(withBase(`/og/zh/${ogSlug}.png`), Astro.site).href
    : undefined);

const articleJsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  inLanguage: lang,
  author: { '@type': 'Person', name: AUTHOR_NAME },
  publisher: { '@type': 'Organization', name: SITE_NAME },
  datePublished: publishDate.toISOString(),
  dateModified: (updatedDiffers ? updatedDate : publishDate).toISOString(),
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
};
if (ogImageUrl) articleJsonLd.image = ogImageUrl;

// 封面圖來源：coverImage 可能是相對路徑字串或已 import 的 ImageMetadata（取 .src）。
const coverSrc =
  typeof coverImage === 'string' ? coverImage : coverImage?.src ?? undefined;

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.label,
    ...(item.href ? { item: new URL(withBase(item.href), Astro.site).href } : {}),
  })),
};

const hasFaq = !!faq && faq.length > 0;
const faqJsonLd = hasFaq
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faq!.map((item) => ({
        '@type': 'Question',
        name: item.q,
        acceptedAnswer: { '@type': 'Answer', text: item.a },
      })),
    }
  : null;

const jsonLdBlocks: Record<string, unknown>[] = [articleJsonLd, breadcrumbJsonLd];
if (faqJsonLd) jsonLdBlocks.push(faqJsonLd);
---

<Base title={seoTitle ?? `${title}｜allmoneyback.me`} description={description} ogTitle={socialTitle} ogDescription={socialDescription ?? description} ogImage={ogImageUrl} ogType="article" lang={lang}>
  <Fragment slot="head">
    <JsonLd data={jsonLdBlocks} />
    <slot name="head" />
  </Fragment>
  <div class="article-layout container">
    <Breadcrumb items={breadcrumbItems} />

    <header class="article-header">
      <div class="article-header__meta">
        <CategoryTag category={category} />
      </div>
      <h1>{title}</h1>
      {witnessVigil && (
        <p class="witness-vigil">{witnessVigil}</p>
      )}
      <AuthorMeta publishDate={publishDate} updatedDate={updatedDate} readingTime={readingTime} />
    </header>

    {coverSrc && (
      <figure class="article-cover">
        {/* 不經 Astro 最佳化（plain img）以保留出廠 C2PA Content Credentials；E13 於 build 驗證憑證。 */}
        <img src={coverSrc} alt={`「${title}」AI 生成封面圖`} width="1536" height="1024" loading="eager" />
        <figcaption class="article-cover__caption">
          AI 生成圖（OpenAI）{coverC2paVerified ? ' · C2PA 已驗證' : ''}
        </figcaption>
      </figure>
    )}

    <div class:list={['article-grid', `article-grid--${variant}`]}>
      <div class="article-content">
        {(method || outcome) && (
          <section class="axis" aria-label="賺錢方式與結果">
            <div class="axis__pair">
              {method && (
                <div class="axis__item">
                  <span class="axis__label">方式</span>
                  <span class="axis__value">{method}</span>
                </div>
              )}
              {method && outcome && <span class="axis__arrow" aria-hidden="true">→</span>}
              {outcome && (
                <div class="axis__item">
                  <span class="axis__label">結果</span>
                  <span class="axis__value">{outcome}</span>
                </div>
              )}
            </div>
          </section>
        )}

        {citationAnswer && <TldrBox summary={citationAnswer} />}

        {comparedCultures.length > 0 && (
          <section class="divergence" aria-label="跨文化分歧">
            <h2 class="divergence__title">不同處境，怎麼想</h2>
            <div class="divergence__grid">
              <div class="divergence__col divergence__col--anchor">
                <span class="divergence__role">基準（錨點）</span>
                <span class="divergence__culture">{anchorCulture}</span>
              </div>
              {comparedCultures.map((culture) => (
                <div class="divergence__col">
                  <span class="divergence__role">對照</span>
                  <span class="divergence__culture">{culture}</span>
                </div>
              ))}
            </div>
            {suspectCultures.length > 0 && (
              <p class="divergence__suspect">
                <span class="divergence__suspect-label">存疑對照（資料黑箱）：</span>
                {suspectCultures.join('、')}
              </p>
            )}
          </section>
        )}

        <div class="prose">
          <slot />
        </div>

        {hasFaq && (
          <section class="article-faq">
            <h2>常見問題</h2>
            <FaqAccordion items={faq!} />
          </section>
        )}

        {sources && sources.length > 0 && (
          <section class="article-references">
            <ReferenceList sources={sources} />
          </section>
        )}

        <AiDisclosure
          writeModel={writeModel}
          critiqueModel={critiqueModel}
          pipelineVersion={pipelineVersion}
          specVersion={specVersion}
          generatedDate={publishDate}
          updatedDate={updatedDate}
        />
        <slot name="after-content" />

        {ogSlug && (
          <Comments slug={ogSlug} apiBase={interactionApi} client:visible />
        )}
      </div>
      <aside class="article-sidebar">
        <slot name="sidebar" />
      </aside>
    </div>
  </div>
</Base>

<style>
  .article-layout {
    padding-block: var(--space-page-y);
  }

  .article-header {
    padding-block: 1.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .article-header__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .article-header h1 {
    max-width: 40ch;
  }

  /* 見證引子：一句克制的俯瞰開場，安靜地放在標題下方。 */
  .witness-vigil {
    margin: 0;
    max-width: 46ch;
    font-size: var(--text-body);
    line-height: 1.7;
    color: color-mix(in oklch, var(--color-ink) 70%, transparent);
    border-left: 3px solid var(--color-accent-light);
    padding-left: 0.9rem;
  }

  /* 方式 → 結果：把文章標示為「一種賺錢方式通往何處」的中性記錄框。 */
  .axis {
    border: 1px solid var(--color-fog);
    border-radius: var(--radius-card);
    padding: 1rem 1.25rem;
  }
  .axis__pair {
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    gap: 0.75rem 1rem;
  }
  .axis__item {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    flex: 1 1 14rem;
    min-width: 0;
  }
  .axis__label {
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    letter-spacing: 0.04em;
    color: color-mix(in oklch, var(--color-ink) 55%, transparent);
  }
  .axis__value {
    font-size: var(--text-body);
    line-height: 1.6;
    color: var(--color-ink);
  }
  .axis__arrow {
    align-self: center;
    font-size: var(--text-h3);
    color: var(--color-accent);
  }

  .article-cover {
    margin: 1.5rem 0 0;
  }
  .article-cover img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-card);
    display: block;
  }
  .article-cover__caption {
    margin-top: 0.5rem;
    font-size: var(--text-meta);
    color: var(--color-ink);
    opacity: 0.7;
  }

  .article-grid {
    display: grid;
    min-width: 0;
    grid-template-columns: 1fr;
    gap: 2rem;
    padding-block: 2rem;
  }

  .article-grid--prose {
    background-color: var(--color-paper);
    border-radius: var(--radius-card);
    padding: clamp(1rem, 0.5rem + 3vw, 2rem);
  }

  .article-grid--cards {
    background: transparent;
    padding: 0;
  }

  .article-grid--cards .article-content {
    max-width: none;
  }

  .article-grid--cards .prose {
    max-width: none;
  }

  .article-content {
    max-width: 68ch;
    min-width: 0;
    overflow-wrap: anywhere;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .divergence {
    border: 1px solid var(--color-fog);
    border-radius: var(--radius-card);
    padding: 1.25rem 1.5rem;
  }

  .divergence__title {
    margin: 0 0 1rem;
    font-family: var(--font-sans);
    font-size: var(--text-h3);
    color: var(--color-ink);
  }

  .divergence__grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 540px) {
    .divergence__grid {
      grid-template-columns: repeat(auto-fit, minmax(8rem, 1fr));
    }
  }

  .divergence__col {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0.75rem 0.9rem;
    border-radius: var(--radius-sm, 0.5rem);
    background-color: color-mix(in oklch, var(--color-fog) 35%, var(--color-paper));
    border: 1px solid var(--color-fog);
  }

  .divergence__col--anchor {
    background-color: var(--color-accent-subtle);
    border-color: var(--color-accent-light);
  }

  .divergence__role {
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    letter-spacing: 0.04em;
    color: color-mix(in oklch, var(--color-ink) 55%, transparent);
  }

  .divergence__culture {
    font-size: var(--text-body);
    font-weight: 600;
    color: var(--color-ink);
  }

  .divergence__suspect {
    margin: 1rem 0 0;
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    line-height: 1.7;
    color: color-mix(in oklch, var(--color-ink) 60%, transparent);
  }

  .divergence__suspect-label {
    font-weight: 600;
    color: color-mix(in oklch, var(--color-ink) 75%, transparent);
  }

  .article-faq {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .article-references {
    margin-top: 0;
  }

  .article-sidebar {
    display: none;
    min-width: 0;
  }

  @media (min-width: 1024px) {
    .article-grid--prose {
      grid-template-columns: minmax(0, 0.7fr) minmax(14rem, 0.3fr);
    }

    .article-sidebar {
      display: block;
      position: sticky;
      top: 6rem;
      align-self: start;
    }
  }
</style>
